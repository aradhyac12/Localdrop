<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0a0a0b">
<title>LocalDrop</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ─── Reset & Variables ─────────────────────────────────────────────────── */
:root {
  --bg: #0a0a0b;
  --surface: #111113;
  --surface2: #18181c;
  --border: rgba(255,255,255,0.07);
  --accent: #00e5a0;
  --accent2: #0af;
  --text: #f0f0f2;
  --muted: #666;
  --danger: #ff4757;
  --radius: 14px;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: var(--bg); color: var(--text);
  font-family: 'Syne', sans-serif;
  min-height: 100vh; overflow-x: hidden;
  -webkit-tap-highlight-color: transparent;
}
body::before {
  content:''; position:fixed; width:600px; height:600px;
  background: radial-gradient(circle, rgba(0,229,160,.06) 0%, transparent 70%);
  top:-200px; left:-200px; pointer-events:none; z-index:0;
}
body::after {
  content:''; position:fixed; width:500px; height:500px;
  background: radial-gradient(circle, rgba(0,170,255,.05) 0%, transparent 70%);
  bottom:-150px; right:-100px; pointer-events:none; z-index:0;
}

/* ─── Header ────────────────────────────────────────────────────────────── */
header {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 28px; border-bottom:1px solid var(--border);
  position:sticky; top:0; background:rgba(10,10,11,.88);
  backdrop-filter:blur(18px); z-index:100;
}
.logo { display:flex; align-items:center; gap:10px; font-size:1.15rem; font-weight:800; letter-spacing:-.03em; }
.logo-icon {
  width:32px; height:32px; border-radius:8px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  display:flex; align-items:center; justify-content:center;
}
.logo-icon svg { width:16px; height:16px; }
.status-pill {
  display:flex; align-items:center; gap:7px;
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  background:var(--surface2); border:1px solid var(--border);
  padding:6px 14px; border-radius:100px; color:var(--muted);
}
.status-dot { width:6px; height:6px; border-radius:50%; background:var(--accent); box-shadow:0 0 6px var(--accent); animation:pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

/* ─── Main layout ───────────────────────────────────────────────────────── */
main { max-width:960px; margin:0 auto; padding:36px 22px 80px; position:relative; z-index:1; }

/* ─── Role selector ─────────────────────────────────────────────────────── */
.role-selector { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:28px; }
.role-btn {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius); padding:18px 22px;
  cursor:pointer; text-align:left; color:var(--text);
  font-family:'Syne',sans-serif; position:relative; overflow:hidden;
  transition:border-color .2s, box-shadow .2s;
}
.role-btn::before { content:''; position:absolute; inset:0; opacity:0; transition:opacity .2s; }
.role-btn.send::before  { background:linear-gradient(135deg,rgba(0,229,160,.09),transparent); }
.role-btn.receive::before { background:linear-gradient(135deg,rgba(0,170,255,.09),transparent); }
.role-btn:hover::before, .role-btn.active::before { opacity:1; }
.role-btn.active { border-color:var(--accent); box-shadow:0 0 0 1px var(--accent),0 0 28px rgba(0,229,160,.08); }
.role-btn.receive.active { border-color:var(--accent2); box-shadow:0 0 0 1px var(--accent2),0 0 28px rgba(0,170,255,.08); }
.role-label { font-size:.62rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:5px; }
.role-title { font-size:1.05rem; font-weight:700; margin-bottom:3px; }
.role-desc  { font-size:.78rem; color:var(--muted); font-weight:400; }

/* ─── Panels ────────────────────────────────────────────────────────────── */
.panel { display:none; }
.panel.active { display:block; animation:fadeUp .28s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

/* ─── Drop zone ─────────────────────────────────────────────────────────── */
.drop-zone {
  border:2px dashed rgba(0,229,160,.22); border-radius:var(--radius);
  padding:52px 36px; text-align:center; cursor:pointer;
  transition:all .2s; background:var(--surface);
}
.drop-zone:hover, .drop-zone.dragging { border-color:var(--accent); background:rgba(0,229,160,.04); }
/* Input is visually hidden but NOT display:none — iOS Safari blocks .click()
   on display:none inputs as a security measure against invisible upload triggers.
   This technique keeps it in the render tree (tappable) while invisible. */
.drop-zone input {
  width: 0.1px;
  height: 0.1px;
  opacity: 0;
  overflow: hidden;
  position: absolute;
  z-index: -1;
}
.drop-icon { width:60px; height:60px; background:rgba(0,229,160,.1); border-radius:14px; margin:0 auto 14px; display:flex; align-items:center; justify-content:center; font-size:1.7rem; }
.drop-title { font-size:1.05rem; font-weight:700; margin-bottom:5px; }
.drop-sub { font-size:.78rem; color:var(--muted); }

/* ─── File list ─────────────────────────────────────────────────────────── */
.file-list { margin-top:14px; display:flex; flex-direction:column; gap:8px; }
.file-item { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:11px 15px; display:flex; align-items:center; gap:11px; animation:fadeUp .2s ease; }
.file-icon { width:34px; height:34px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.95rem; flex-shrink:0; }
.file-icon.img { background:rgba(255,71,87,.15); }
.file-icon.vid { background:rgba(0,170,255,.15); }
.file-icon.doc { background:rgba(255,165,0,.15); }
.file-icon.other { background:rgba(160,160,160,.1); }
.file-info { flex:1; min-width:0; }
.file-name { font-size:.83rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.file-size { font-size:.7rem; color:var(--muted); font-family:'JetBrains Mono',monospace; }
.file-remove { background:none; border:none; color:var(--muted); cursor:pointer; font-size:1rem; transition:color .15s; padding:4px; }
.file-remove:hover { color:var(--danger); }

/* ─── QR section ────────────────────────────────────────────────────────── */
.qr-section {
  display:grid; grid-template-columns:auto 1fr; gap:22px;
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius); padding:22px; margin-top:14px; align-items:start;
}
.qr-box { background:#fff; border-radius:10px; padding:8px; display:inline-flex; align-items:center; justify-content:center; }
.qr-box canvas { display:block; border-radius:6px; }
.qr-meta { }
.qr-label { font-size:.62rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--accent); margin-bottom:7px; }
.qr-title { font-size:.98rem; font-weight:700; margin-bottom:5px; }
.qr-desc  { font-size:.78rem; color:var(--muted); line-height:1.55; margin-bottom:12px; }
.qr-status { font-size:.75rem; color:var(--muted); font-style:italic; margin-top:8px; }

/* ─── Text fallback ─────────────────────────────────────────────────────── */
.text-fallback {
  background:var(--surface2); border:1px solid var(--border);
  border-radius:10px; padding:16px; margin-top:12px;
}
.text-fallback label { font-size:.7rem; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:8px; }
.text-fallback textarea {
  width:100%; background:var(--bg); border:1px solid var(--border);
  border-radius:8px; padding:10px; color:var(--accent);
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  resize:vertical; min-height:80px; outline:none;
}
.text-fallback textarea:focus { border-color:rgba(0,229,160,.4); }

/* ─── Scanner viewfinder ────────────────────────────────────────────────── */
.scanner-wrap {
  border-radius:var(--radius); overflow:hidden;
  border:2px solid rgba(0,229,160,.3); margin-top:14px;
  min-height:260px; background:#000; position:relative;
}
.scanner-wrap #scanAnswerDiv,
.scanner-wrap #scanOfferDiv { width:100%; }

/* ─── Scan section ──────────────────────────────────────────────────────── */
.scan-area {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius); padding:38px 28px; text-align:center;
}
.scan-icon { width:76px; height:76px; margin:0 auto 18px; }
.scan-icon svg { width:76px; height:76px; }
.scan-title { font-size:1.05rem; font-weight:700; margin-bottom:7px; }
.scan-desc  { font-size:.8rem; color:var(--muted); max-width:320px; margin:0 auto 22px; line-height:1.6; }

/* ─── Transfer card ─────────────────────────────────────────────────────── */
.transfer-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:22px; margin-top:14px; }
.transfer-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; }
.transfer-title { font-size:.9rem; font-weight:700; }
.transfer-speed { font-family:'JetBrains Mono',monospace; font-size:.78rem; color:var(--accent); background:rgba(0,229,160,.1); padding:4px 10px; border-radius:6px; display:flex; align-items:center; gap:6px; }
.speed-dot { width:5px; height:5px; border-radius:50%; background:var(--accent); animation:pulse .8s ease-in-out infinite; }
.progress-items { display:flex; flex-direction:column; gap:13px; }
.progress-item { }
.progress-top { display:flex; justify-content:space-between; margin-bottom:6px; font-size:.78rem; }
.progress-name { font-weight:600; }
.progress-pct  { font-family:'JetBrains Mono',monospace; color:var(--muted); font-size:.73rem; }
.progress-bar-bg { height:5px; background:var(--surface2); border-radius:100px; overflow:hidden; }
.progress-bar { height:100%; border-radius:100px; background:linear-gradient(90deg,var(--accent),var(--accent2)); transition:width .25s ease; position:relative; }
.progress-bar::after { content:''; position:absolute; top:0; right:0; bottom:0; width:40px; background:linear-gradient(90deg,transparent,rgba(255,255,255,.25)); animation:shimmer 1.2s linear infinite; }
@keyframes shimmer { from{transform:translateX(-40px)} to{transform:translateX(40px)} }
.progress-sub { margin-top:4px; font-size:.68rem; color:var(--muted); font-family:'JetBrains Mono',monospace; }

/* ─── Stats row ─────────────────────────────────────────────────────────── */
.stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:11px; margin-top:14px; }
.stat-card { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:13px 15px; }
.stat-label { font-size:.62rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-bottom:5px; }
.stat-val { font-family:'JetBrains Mono',monospace; font-size:1.05rem; font-weight:500; }

/* ─── Incoming card (receiver) ──────────────────────────────────────────── */
.incoming-card { background:var(--surface); border:1px solid rgba(0,170,255,.3); border-radius:var(--radius); padding:22px; margin-top:14px; box-shadow:0 0 28px rgba(0,170,255,.05); display:none; }
.incoming-card.visible { display:block; animation:fadeUp .3s ease; }
.incoming-label { font-size:.62rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--accent2); margin-bottom:11px; }

/* ─── Buttons ───────────────────────────────────────────────────────────── */
.btn { display:inline-flex; align-items:center; gap:8px; padding:11px 22px; border-radius:10px; border:none; font-family:'Syne',sans-serif; font-weight:600; font-size:.88rem; cursor:pointer; transition:all .18s; }
.btn:disabled { opacity:.45; cursor:not-allowed; }
.btn-primary  { background:var(--accent); color:#000; }
.btn-primary:hover:not(:disabled)  { background:#00ffb3; transform:translateY(-1px); box-shadow:0 8px 20px rgba(0,229,160,.28); }
.btn-secondary { background:var(--surface2); color:var(--text); border:1px solid var(--border); }
.btn-secondary:hover { border-color:rgba(255,255,255,.2); }
.btn-accent2  { background:var(--accent2); color:#000; }
.btn-accent2:hover:not(:disabled) { background:#33bbff; transform:translateY(-1px); box-shadow:0 8px 20px rgba(0,170,255,.28); }
.btn-sm { padding:7px 14px; font-size:.78rem; border-radius:8px; }
.actions { display:flex; gap:9px; margin-top:18px; flex-wrap:wrap; }

/* ─── Section label ─────────────────────────────────────────────────────── */
.section-label { font-size:.62rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin:22px 0 11px; display:flex; align-items:center; gap:10px; }
.section-label::after { content:''; flex:1; height:1px; background:var(--border); }

/* ─── IP tag ─────────────────────────────────────────────────────────────── */
.ip-tag { font-family:'JetBrains Mono',monospace; font-size:.72rem; background:var(--surface2); border:1px solid var(--border); padding:5px 10px; border-radius:6px; display:inline-block; color:var(--accent); }

/* ─── Step badge ────────────────────────────────────────────────────────── */
.step-badge { display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:50%; background:var(--accent); color:#000; font-size:.68rem; font-weight:800; flex-shrink:0; }
.step-badge.b2 { background:var(--accent2); }

/* ─── Toast ─────────────────────────────────────────────────────────────── */
.toast-container { position:fixed; bottom:24px; right:20px; display:flex; flex-direction:column; gap:7px; z-index:1000; max-width:320px; }
.toast { background:var(--surface2); border:1px solid var(--border); padding:11px 16px; border-radius:10px; font-size:.8rem; display:flex; align-items:center; gap:8px; animation:toastIn .22s ease; box-shadow:0 8px 28px rgba(0,0,0,.5); }
.toast.success { border-color:rgba(0,229,160,.35); }
.toast.info    { border-color:rgba(0,170,255,.35); }
.toast.error   { border-color:rgba(255,71,87,.35); }
@keyframes toastIn { from{opacity:0;transform:translateX(18px)} to{opacity:1;transform:translateX(0)} }

/* ─── Handshake step labels ─────────────────────────────────────────────── */
.handshake-steps { display:flex; flex-direction:column; gap:10px; margin-bottom:18px; }
.hs-step { display:flex; align-items:flex-start; gap:10px; font-size:.82rem; color:var(--muted); }
.hs-step.active { color:var(--text); }
.hs-step.done   { color:var(--accent); }

/* ─── Responsive ────────────────────────────────────────────────────────── */
@media(max-width:600px){
  header { padding:14px 16px; }
  main { padding:18px 14px 80px; }
  .role-selector { grid-template-columns:1fr; }
  .qr-section { grid-template-columns:1fr; }
  .qr-box { margin:0 auto; }
  .stats-row { grid-template-columns:1fr 1fr; }
  .actions { flex-direction:column; }
  .btn { justify-content:center; }
}
</style>
</head>
<body>

<!-- ── Header ──────────────────────────────────────────────────────────────── -->
<header>
  <div class="logo">
    <div class="logo-icon">
      <svg viewBox="0 0 16 16" fill="none"><path d="M8 2L14 6V10L8 14L2 10V6L8 2Z" stroke="#000" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 2V14M2 6L14 10M14 6L2 10" stroke="#000" stroke-width="1" opacity=".5"/></svg>
    </div>
    LocalDrop
  </div>
  <div class="status-pill">
    <div class="status-dot"></div>
    Offline P2P
  </div>
</header>

<main>

  <!-- Role selector -->
  <div class="role-selector">
    <button class="role-btn send active" onclick="setRole('send',this)">
      <div class="role-label">Mode</div>
      <div class="role-title">↑ Send Files</div>
      <div class="role-desc">Share files from this device</div>
    </button>
    <button class="role-btn receive" onclick="setRole('receive',this)">
      <div class="role-label">Mode</div>
      <div class="role-title">↓ Receive Files</div>
      <div class="role-desc">Scan QR to accept files</div>
    </button>
  </div>

  <!-- ════════════════════════════════════════════════════════════════════
       SEND PANEL
       ════════════════════════════════════════════════════════════════════ -->
  <div class="panel active" id="panel-send">

    <!-- STEP 1: Select Files -->
    <div class="section-label"><span class="step-badge">1</span> Select Files</div>
    <!-- Using <label for="fileInput"> instead of <div onclick> — this is the
         only reliable cross-platform way to open the file picker on iOS Safari
         and Android WebView. Native label→input association bypasses the
         security restriction that blocks programmatic .click() on file inputs. -->
    <label class="drop-zone" id="dropZone" for="fileInput">
      <input type="file" id="fileInput" multiple>
      <div class="drop-icon">📁</div>
      <div class="drop-title">Drop files here</div>
      <div class="drop-sub">or tap to browse · any file type · 1 GB+ supported</div>
    </label>
    <div class="file-list" id="fileList"></div>

    <!-- Actions after file selection -->
    <div class="actions" id="sendActions" style="display:none">
      <button class="btn btn-primary" id="btnGenQR">⚡ Generate Offer QR</button>
      <button class="btn btn-secondary btn-sm" onclick="clearFiles()">✕ Clear</button>
    </div>

    <!-- STEP 2: Offer QR (sender displays this) -->
    <div id="qrSection" style="display:none">
      <div class="section-label"><span class="step-badge">2</span> Show this QR to Receiver</div>
      <div class="qr-section">
        <div class="qr-box"><canvas id="qrCanvas"></canvas></div>
        <div class="qr-meta">
          <div class="qr-label">↑ Offer ready</div>
          <div class="qr-title">Receiver scans this</div>
          <div class="qr-desc">Ask the receiver to open LocalDrop, tap "Receive", then scan this QR. No internet required — pure WebRTC over Wi-Fi.</div>
          <div class="qr-status" id="qrStatusText">Waiting for receiver to scan…</div>
        </div>
      </div>

      <!-- Text fallback (if QR payload too large OR no camera on receiver) -->
      <div class="text-fallback" id="textFallbackBox" style="display:none">
        <label>Text fallback — copy &amp; paste this on the receiver:</label>
        <textarea id="textFallbackInput" readonly onclick="this.select()"></textarea>
        <div class="actions">
          <button class="btn btn-secondary btn-sm" id="btnCopyOffer">📋 Copy text</button>
        </div>
      </div>
    </div>

    <!-- STEP 3: Scan Receiver's Answer -->
    <div id="scanAnswerSection" style="display:none">
      <div class="section-label"><span class="step-badge">3</span> Scan Receiver's Answer QR</div>
      <div class="scan-area" style="padding:24px">
        <div class="scan-title">Now scan the QR shown on the receiver's screen</div>
        <div class="scan-desc">The receiver's device will show an Answer QR after scanning your offer. Scan it here to complete the handshake.</div>
        <div class="actions" style="justify-content:center">
          <button class="btn btn-primary" id="btnScanAnswer">📷 Open Camera</button>
        </div>
        <div class="scanner-wrap" style="display:none" id="scanAnswerWrap">
          <div id="scanAnswerDiv"></div>
        </div>
        <!-- Manual paste fallback -->
        <div class="text-fallback" id="manualAnswerBox" style="display:none; margin-top:14px">
          <label>No camera? Paste the receiver's answer text here:</label>
          <textarea id="pastedAnswerInput" placeholder="Paste the compressed answer string…"></textarea>
          <div class="actions">
            <button class="btn btn-accent2 btn-sm" id="btnApplyPastedAnswer">✓ Apply Answer</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Transfer progress (sender) -->
    <div id="transferSection" style="display:none">
      <div class="section-label">Transfer Progress</div>
      <div class="transfer-card">
        <div class="transfer-header">
          <div class="transfer-title" id="transferTitle">Preparing…</div>
          <div class="transfer-speed"><div class="speed-dot"></div><span id="speedVal">— MB/s</span></div>
        </div>
        <div class="progress-items" id="progressItems"></div>
      </div>
      <div class="stats-row">
        <div class="stat-card"><div class="stat-label">Transferred</div><div class="stat-val" id="statTransferred">—</div></div>
        <div class="stat-card"><div class="stat-label">Elapsed</div><div class="stat-val" id="statElapsed">0:00</div></div>
        <div class="stat-card"><div class="stat-label">ETA</div><div class="stat-val" id="statETA">—</div></div>
      </div>
    </div>

  </div><!-- /panel-send -->


  <!-- ════════════════════════════════════════════════════════════════════
       RECEIVE PANEL
       ════════════════════════════════════════════════════════════════════ -->
  <div class="panel" id="panel-receive">

    <!-- STEP 1: Scan sender's offer -->
    <div class="section-label"><span class="step-badge b2">1</span> Scan Sender's Offer QR</div>
    <div class="scan-area">
      <div class="scan-icon">
        <svg viewBox="0 0 76 76" fill="none">
          <rect x="9" y="9" width="17" height="3" fill="#00e5a0"/>
          <rect x="9" y="9" width="3" height="17" fill="#00e5a0"/>
          <rect x="50" y="9" width="17" height="3" fill="#00e5a0"/>
          <rect x="64" y="9" width="3" height="17" fill="#00e5a0"/>
          <rect x="9" y="64" width="17" height="3" fill="#00e5a0"/>
          <rect x="9" y="50" width="3" height="17" fill="#00e5a0"/>
          <rect x="50" y="64" width="17" height="3" fill="#00e5a0"/>
          <rect x="64" y="50" width="3" height="17" fill="#00e5a0"/>
          <rect x="12" y="37" width="52" height="2" rx="1" fill="rgba(0,229,160,0.4)">
            <animate attributeName="y" from="16" to="58" dur="1.6s" repeatCount="indefinite"/>
          </rect>
        </svg>
      </div>
      <div class="scan-title">Point camera at sender's QR</div>
      <div class="scan-desc">The sender will display a QR code after selecting files. Scan it here — everything stays on your local Wi-Fi.</div>
      <div class="actions" style="justify-content:center">
        <button class="btn btn-accent2" id="btnScanOffer">📷 Scan Offer QR</button>
      </div>
      <div class="scanner-wrap" id="scanOfferWrap" style="display:none">
        <div id="scanOfferDiv"></div>
      </div>
    </div>

    <!-- Manual offer paste (no camera) -->
    <div class="text-fallback" id="manualOfferBox" style="display:none; margin-top:14px">
      <label>No camera? Paste the sender's offer text here:</label>
      <textarea id="offerTextInput" placeholder="Paste the compressed offer string from the sender…"></textarea>
      <div class="actions">
        <button class="btn btn-accent2 btn-sm" id="btnApplyTextOffer">✓ Apply Offer</button>
      </div>
    </div>

    <!-- STEP 2: Show answer QR to sender -->
    <div id="answerQrSection" style="display:none">
      <div class="section-label"><span class="step-badge b2">2</span> Show This Answer QR to Sender</div>
      <div class="qr-section">
        <div class="qr-box"><canvas id="answerQrCanvas"></canvas></div>
        <div class="qr-meta">
          <div class="qr-label" style="color:var(--accent2)">↑ Answer ready</div>
          <div class="qr-title">Sender scans this</div>
          <div class="qr-desc">Ask the sender to scan this QR (Step 3 on their screen). Once they do, the P2P connection opens and files transfer automatically.</div>
          <div class="qr-status" id="answerQrStatus">Waiting for sender to scan…</div>
        </div>
      </div>
      <!-- Text fallback for answer -->
      <div class="text-fallback" id="answerTextBox" style="display:none">
        <label>Text fallback — send this answer text to the sender:</label>
        <textarea id="answerTextInput" readonly onclick="this.select()"></textarea>
        <div class="actions">
          <button class="btn btn-secondary btn-sm" id="btnCopyAnswer">📋 Copy answer</button>
        </div>
      </div>
    </div>

    <!-- Receiving progress -->
    <div class="incoming-card" id="incomingCard">
      <div class="incoming-label">↓ Incoming Transfer</div>
      <div class="transfer-header">
        <div class="transfer-title" id="rxTitle">Connected — receiving…</div>
        <div class="transfer-speed" style="background:rgba(0,170,255,.1);color:var(--accent2)">
          <div class="speed-dot" style="background:var(--accent2)"></div>
          <span id="rxSpeed">— MB/s</span>
        </div>
      </div>
      <div class="progress-items" id="rxProgressItems"></div>
      <div class="stats-row" style="margin-top:14px">
        <div class="stat-card"><div class="stat-label">Received</div><div class="stat-val" id="rxStatTransferred">—</div></div>
        <div class="stat-card"><div class="stat-label">Elapsed</div><div class="stat-val" id="rxStatElapsed">0:00</div></div>
        <div class="stat-card"><div class="stat-label">ETA</div><div class="stat-val" id="rxStatETA">—</div></div>
      </div>
    </div>

  </div><!-- /panel-receive -->

</main>

<!-- Toast container -->
<div class="toast-container" id="toasts"></div>

<!-- ── Scanner script (html5-qrcode needs the div present before init) -->
<!-- Wire scanner viewfinder visibility via JS -->
<script>
  // Expose scanner wrap toggle so app.js can show/hide the viewfinder div
  window._showScanWrap = (id, show) => {
    const el = document.getElementById(id);
    if (el) el.style.display = show ? 'block' : 'none';
  };
</script>

<script type="module" src="/src/main.js"></script>
</body>
</html>
